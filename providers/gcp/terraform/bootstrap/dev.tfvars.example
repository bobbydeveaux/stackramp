platform_project = "my-platform-dev"
github_owner     = "my-github-org"
environment      = "dev"
region           = "europe-west1"
# billing_account = "XXXXXX-XXXXXX-XXXXXX"  # optional
# base_domain     = "myapp.io"               # optional: creates Cloud DNS zone + enables custom subdomains
# create_dns_zone = false                    # set to false if the DNS zone already exists (e.g. created by GCP domain registration)
# machine_consumers = ["agentops"]           # optional: keyless SAs for external systems calling apps' MCP services (allow-listed per-app via mcp.allowed_service_accounts)
