{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stackramp.yaml",
  "description": "StackRamp application configuration",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Application name (slug). Used for service names, URLs, etc."
    },
    "frontend": {
      "type": "object",
      "properties": {
        "framework": {
          "type": "string",
          "enum": [
            "react",
            "vue",
            "next",
            "static",
            "none"
          ],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "frontend"
        },
        "node_version": {
          "type": "string",
          "default": "20"
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "python",
            "go",
            "node",
            "rust",
            "none"
          ],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "backend"
        },
        "port": {
          "type": "integer",
          "default": 8080
        },
        "memory": {
          "type": "string",
          "default": "512Mi"
        },
        "cpu": {
          "type": "string",
          "default": "1"
        },
        "public": {
          "type": "boolean",
          "default": false,
          "description": "Deploy with --allow-unauthenticated (allUsers invoker) so MCP OAuth discovery is reachable by clients like Claude Code. Requires an org policy that permits allUsers; auth is then enforced in-app (bearer tokens via the MCP OAuth flow)."
        }
      }
    },
    "domain": {
      "type": "string",
      "description": "Custom domain for this app (e.g. stackramp.io or myapp.com). Omit to use {app_name}.{STACKRAMP_BASE_DOMAIN}.",
      "pattern": "^([a-z0-9-]+\\.)+[a-z]{2,}$"
    },
    "database": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "enum": [
            "postgres",
            "mysql"
          ]
        }
      ],
      "default": false
    },
    "security": {
      "type": "object",
      "description": "Guardian security scanning. Enabled by default.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "scan_osv": {
          "type": "boolean",
          "default": true
        },
        "scan_secrets": {
          "type": "boolean",
          "default": true
        },
        "scan_sast": {
          "type": "boolean",
          "default": true
        },
        "fail_on_findings": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "storage": {
      "description": "Object storage. Scalar forms (false | gcs) keep the legacy single-bucket behaviour. The object form declares one or more named private GCS buckets.",
      "default": false,
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "enum": [
            "gcs"
          ]
        },
        {
          "type": "object",
          "required": [
            "buckets"
          ],
          "additionalProperties": false,
          "properties": {
            "buckets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Logical bucket name. Injected as env var BUCKET_<NAME_UPPER>. Resolves to bucket gs://{project}-{app}-{env}-{name}."
                  },
                  "access": {
                    "type": "string",
                    "enum": [
                      "private",
                      "public"
                    ],
                    "default": "private",
                    "description": "Bucket access. Only 'private' (the default) is supported: public access prevention is enforced. 'public' is reserved for a future release and is currently rejected at validation time (public buckets / CDN fronting are out of scope)."
                  },
                  "signed_urls": {
                    "type": "boolean",
                    "default": false,
                    "description": "Grant the Cloud Run runtime SA token-creator on itself so the backend can mint keyless V4 signed URLs (signBlob, no key file)."
                  },
                  "lifecycle_days": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0,
                    "description": "Age-based delete lifecycle rule in days. 0 = no rule."
                  }
                }
              }
            }
          }
        }
      ]
    },
    "mcp": {
      "type": "object",
      "description": "MCP (Model Context Protocol) server. Deployed as a separate Cloud Run service with domain-restricted invoker \u2014 no IAP, no allUsers.",
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "python",
            "go",
            "node",
            "rust"
          ],
          "default": "go"
        },
        "dir": {
          "type": "string",
          "default": "mcp"
        },
        "port": {
          "type": "integer",
          "default": 8080
        },
        "memory": {
          "type": "string",
          "default": "256Mi"
        },
        "cpu": {
          "type": "string",
          "default": "1"
        },
        "public": {
          "type": "boolean",
          "default": false,
          "description": "Allow unauthenticated Cloud Run invocation (required for MCP OAuth discovery); auth is enforced in-app on /v1/mcp."
        },
        "allowed_service_accounts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Machine consumer SA emails allowed to call this MCP service with Google-signed ID tokens (e.g. agentops@project.iam.gserviceaccount.com \u2014 provisioned by the bootstrap's machine_consumers). Injected into the MCP service as MCP_SERVICE_ACCOUNTS, semicolon-joined."
        }
      }
    },
    "quality": {
      "type": "object",
      "description": "Pulse code quality gates. Enabled by default.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "max_ccn": {
          "type": "integer",
          "default": 15,
          "minimum": 1
        },
        "max_cognitive": {
          "type": "integer",
          "default": 20,
          "minimum": 1
        },
        "max_duplication": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 100
        },
        "min_maintainability": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "maximum": 100
        },
        "fail_on_gate": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "kubernetes": {
      "type": "object",
      "description": "Helm release on the shared GKE cluster (bootstrap enable_gke). For apps that need a real k8s cluster \u2014 dispatch k8s Jobs, run a Helm chart \u2014 rather than Cloud Run.",
      "properties": {
        "chart": {
          "type": "string",
          "description": "Path to the Helm chart in the repo (default deploy/helm/<app>)."
        },
        "namespace": {
          "type": "string",
          "description": "Base namespace (default: app name). The deploy env is appended, so dev installs into <namespace>-dev and prod into <namespace>-prod on the same shared cluster."
        },
        "values": {
          "type": "object",
          "description": "Inline Helm value overrides."
        },
        "images": {
          "type": "array",
          "description": "Images StackRamp builds + pushes to Artifact Registry before helm install (tag = git SHA). Each maps to a Helm value the chart references. Images NOT listed (e.g. a cross-repo dependency) must be pre-published and pinned in the chart's values.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "dockerfile"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Image name under the shared registry (e.g. agentops-api)."
              },
              "dockerfile": {
                "type": "string",
                "description": "Path to the Dockerfile (e.g. Dockerfile.api)."
              },
              "context": {
                "type": "string",
                "description": "Docker build context (default: repo root)."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
