{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stackramp.yaml",
  "description": "StackRamp application configuration",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Application name (slug). Used for service names, URLs, etc."
    },
    "frontend": {
      "type": "object",
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["react", "vue", "next", "static", "none"],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "frontend"
        },
        "node_version": {
          "type": "string",
          "default": "20"
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python", "go", "node", "rust", "none"],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "backend"
        },
        "port": {
          "type": "integer",
          "default": 8080
        },
        "memory": {
          "type": "string",
          "default": "512Mi"
        },
        "cpu": {
          "type": "string",
          "default": "1"
        }
      }
    },
    "domain": {
      "type": "string",
      "description": "Custom domain for this app (e.g. stackramp.io or myapp.com). Omit to use {app_name}.{STACKRAMP_BASE_DOMAIN}.",
      "pattern": "^([a-z0-9-]+\\.)+[a-z]{2,}$"
    },
    "database": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "enum": ["postgres", "mysql"] }
      ],
      "default": false
    },
    "security": {
      "type": "object",
      "description": "Guardian security scanning. Enabled by default.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "scan_osv": { "type": "boolean", "default": true },
        "scan_secrets": { "type": "boolean", "default": true },
        "scan_sast": { "type": "boolean", "default": true },
        "fail_on_findings": { "type": "boolean", "default": true }
      }
    },
    "storage": {
      "description": "Object storage. Scalar forms (false | gcs) keep the legacy single-bucket behaviour. The object form declares one or more named private GCS buckets.",
      "default": false,
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "enum": ["gcs"] },
        {
          "type": "object",
          "required": ["buckets"],
          "additionalProperties": false,
          "properties": {
            "buckets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9-]*$",
                    "description": "Logical bucket name. Injected as env var BUCKET_<NAME_UPPER>. Resolves to bucket gs://{project}-{app}-{env}-{name}."
                  },
                  "access": {
                    "type": "string",
                    "enum": ["private", "public"],
                    "default": "private",
                    "description": "Bucket access. Only 'private' (the default) is supported: public access prevention is enforced. 'public' is reserved for a future release and is currently rejected at validation time (public buckets / CDN fronting are out of scope)."
                  },
                  "signed_urls": {
                    "type": "boolean",
                    "default": false,
                    "description": "Grant the Cloud Run runtime SA token-creator on itself so the backend can mint keyless V4 signed URLs (signBlob, no key file)."
                  },
                  "lifecycle_days": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0,
                    "description": "Age-based delete lifecycle rule in days. 0 = no rule."
                  }
                }
              }
            }
          }
        }
      ]
    },
    "quality": {
      "type": "object",
      "description": "Pulse code quality gates. Enabled by default.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "max_ccn": { "type": "integer", "default": 15, "minimum": 1 },
        "max_cognitive": { "type": "integer", "default": 20, "minimum": 1 },
        "max_duplication": { "type": "number", "default": 5, "minimum": 0, "maximum": 100 },
        "min_maintainability": { "type": "number", "default": 40, "minimum": 0, "maximum": 100 },
        "fail_on_gate": { "type": "boolean", "default": true }
      }
    }
  }
}
