{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stackramp.yaml",
  "description": "StackRamp application configuration",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Application name (slug). Used for service names, URLs, etc."
    },
    "frontend": {
      "type": "object",
      "properties": {
        "framework": {
          "type": "string",
          "enum": ["react", "vue", "next", "static", "none"],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "frontend"
        },
        "node_version": {
          "type": "string",
          "default": "20"
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "enum": ["python", "go", "node", "rust", "none"],
          "default": "none"
        },
        "dir": {
          "type": "string",
          "default": "backend"
        },
        "port": {
          "type": "integer",
          "default": 8080
        },
        "memory": {
          "type": "string",
          "default": "512Mi"
        },
        "cpu": {
          "type": "string",
          "default": "1"
        },
        "iam": {
          "type": "array",
          "description": "Cross-project IAM bindings for the Cloud Run service account",
          "items": {
            "type": "object",
            "required": ["role", "project"],
            "properties": {
              "role": {
                "type": "string",
                "description": "IAM role to grant (e.g. roles/bigquery.dataViewer)",
                "pattern": "^roles/[a-zA-Z.]+$"
              },
              "project": {
                "type": "string",
                "description": "Target GCP project ID for the binding"
              },
              "resource": {
                "type": "string",
                "description": "Optional resource path for resource-level bindings (e.g. datasets/my_dataset for BigQuery dataset-level grants)"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "domain": {
      "type": "string",
      "description": "Custom domain for this app (e.g. stackramp.io or myapp.com). Omit to use {app_name}.{STACKRAMP_BASE_DOMAIN}.",
      "pattern": "^([a-z0-9-]+\\.)+[a-z]{2,}$"
    },
    "database": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string", "enum": ["postgres", "mysql"] }
      ],
      "default": false
    }
  }
}
